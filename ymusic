def run_cmd(cmd, timeout=30, retries=2, cancel=None):
    env = os.environ.copy()
    env["PATH"] = os.path.expanduser("~/.deno/bin") + ":" + env.get("PATH", "")
    for i in range(retries):
        if cancel and cancel.is_set():
            return "", "", -1
        proc = subprocess.Popen(cmd, stdout=subprocess.PIPE, stderr=subprocess.PIPE,
                                text=True, env=env)
        deadline = time.time() + timeout
        while time.time() < deadline:
            if cancel and cancel.is_set():
                proc.kill()
                return "", "", -1
            try:
                stdout, stderr = proc.communicate(timeout=0.5)
                break
            except subprocess.TimeoutExpired:
                continue
        else:
            proc.kill()
            proc.communicate()
            continue
        if proc.returncode == 0 or ("429" not in stderr and "Too Many" not in stderr):
            return stdout, stderr, proc.returncode
        if i < retries - 1:
            for _ in range(4):
                if cancel and cancel.is_set():
                    return "", "", -1
                time.sleep(0.5)
    return "", "Failed", 1


_search_cache = {}

_YT_OPTS = []

def search_yt(query, limit=10):
    key = f"{query}:{limit}"
    if key in _search_cache:
        ts, cached = _search_cache[key]
        if time.time() - ts < 120:
            return cached
    cmd = ["yt-dlp"] + _YT_OPTS + ["--dump-json", "--flat-playlist",
           "-I", f"1:{limit}", f"ytsearch{limit}:{query}"]
    out, _, code = run_cmd(cmd, 60, 1)
    results = []
    for line in out.strip().split("\n"):
        if not line.strip():
            continue
        try:
            d = json.loads(line)
            results.append({"id": d.get("id",""), "title": d.get("title","Unknown"),
                            "uploader": d.get("uploader","Unknown"),
                            "duration": d.get("duration",0), "views": d.get("view_count",0)})
        except:
            pass
    _search_cache[key] = (time.time(), results)
    return results


_recs_cache = {}
_stream_url_cache = {}

def get_related(query, video_id, limit=10, cancel=None):
    key = video_id
    if key in _recs_cache:
        ts, cached = _recs_cache[key]
        if time.time() - ts < 300:
            return cached
    mix_url = f"https://youtube.com/watch?v={video_id}&list=RDMM{video_id}"
    cmd = ["yt-dlp"] + _YT_OPTS + ["--dump-json", "--flat-playlist",
           "-I", f"1:{limit+2}", mix_url]
    out, _, code = run_cmd(cmd, 30, 1, cancel=cancel)
    if cancel and cancel.is_set():
        return []
    results = []
    for line in out.strip().split("\n"):
        if not line.strip():
            continue
        try:
            d = json.loads(line)
            if d.get("_type") != "url" or not d.get("id") or d["id"] == video_id:
                continue
            results.append({"id": d["id"], "title": d.get("title","Unknown"),
                            "uploader": d.get("uploader") or d.get("channel","Unknown"),
                            "duration": d.get("duration",0), "views": d.get("view_count",0)})
        except:
            pass
    results = results[:limit]
    _recs_cache[key] = (time.time(), results)
    return results


def get_stream_url(video_id, cancel=None):
    if video_id in _stream_url_cache:
        return _stream_url_cache[video_id]
    cmd = ["yt-dlp"] + _YT_OPTS + ["-g", "--format", "bestaudio",
           f"https://youtu.be/{video_id}"]
    out, _, code = run_cmd(cmd, 30, 2, cancel=cancel)
    if cancel and cancel.is_set():
        return ""
    if code == 0 and "googlevideo.com" in out:
        url = out.strip()
        _stream_url_cache[video_id] = url
        return url
    return ""


def fmt_dur(s):
    if not s:
        return ""
    m, s = divmod(int(s), 60)
    h, m = divmod(m, 60)
    return f"{h}:{m:02d}:{s:02d}" if h else f"{m}:{s:02d}"


def fmt_views(n):
    if not n:
        return ""
    if n >= 1_000_000:
        return f"{n/1_000_000:.1f}M"
    if n >= 1_000:
        return f"{n/1_000:.1f}K"
    return str(n)


def load_liked():
    if LIKED_FILE.exists():
        return json.loads(LIKED_FILE.read_text())
    return []


def save_liked(tracks):
    LIKED_FILE.write_text(json.dumps(tracks, indent=2))


def is_liked(vid):
    return any(t["id"] == vid for t in load_liked())


def toggle_like(track):
    liked = load_liked()
    if any(t["id"] == track["id"] for t in liked):
        liked = [t for t in liked if t["id"] != track["id"]]
        save_liked(liked)
        return False
    liked.insert(0, track)
    save_liked(liked)
    return True





class PlayerManager:
    """Thread-safe single-track player. Only one track plays at a time."""

    def __init__(self, on_state_change=None, on_position=None):
        self._lock = threading.Lock()
        self._proc = None
        self._cancel = threading.Event()
        self._track = None
        self._state = "stopped"  # stopped | loading | playing | ended | failed
        self._on_state = on_state_change
        self._on_position = on_position

        self._ipc_path = None
        self._position = 0.0
        self._duration = 0.0
        self._paused = False
        self._volume = 100
        self._loop = "none"
        self._seeking = False
        self._queue = []

    @property
    def track(self):
        return self._track

    @property
    def state(self):
        return self._state

    @property
    def paused(self):
        return self._paused

    @property
    def position(self):
        return self._position

    @property
    def duration(self):
        return self._duration

    @property
    def volume(self):
        return self._volume

    @property
    def loop(self):
        return self._loop

    @property
    def queue(self):
        return list(self._queue)

    # ── IPC helpers ──

    def _send_ipc(self, cmd):
        if not self._ipc_path or not os.path.exists(self._ipc_path):
            return None
        sock = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
        sock.settimeout(3)
        try:
            sock.connect(self._ipc_path)
            sock.sendall(json.dumps(cmd).encode() + b"\n")
            resp = b""
            while True:
                chunk = sock.recv(4096)
                if not chunk:
                    break
                resp += chunk
                if b"\n" in resp:
                    break
            return json.loads(resp.decode())
        except:
            return None
        finally:
            sock.close()

    def _start_polling(self, cancel):
        def poll():
            sock = None
            try:
                while not cancel.is_set():
                    if self._ipc_path and os.path.exists(self._ipc_path):
                        try:
                            if sock is None:
                                sock = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
                                sock.settimeout(2)
                                sock.connect(self._ipc_path)
                            sock.sendall(json.dumps({"command": ["get_property", "time-pos"]}).encode() + b"\n")
                            resp = b""
                            while True:
                                chunk = sock.recv(4096)
                                if not chunk:
                                    break
                                resp += chunk
                                if b"\n" in resp:
                                    break
                            if resp:
                                d = json.loads(resp.decode())
                                if "data" in d and d["data"] is not None:
                                    self._position = d["data"]
                                    if not self._seeking and self._on_position:
                                        GLib.idle_add(self._on_position, self._position)
                        except (ConnectionRefusedError, FileNotFoundError, BrokenPipeError, OSError):
                            if sock:
                                try:
                                    sock.close()
                                except:
                                    pass
                            sock = None
                        except:
                            pass
                    with self._lock:
                        p = self._proc
                    if p and p.poll() is not None:
                        break
                    for _ in range(10):
                        if cancel.is_set():
                            return
                        time.sleep(0.05)
            finally:
                if sock:
                    try:
                        sock.close()
                    except:
                        pass

        threading.Thread(target=poll, daemon=True).start()

    def _cleanup_ipc(self):
        path = self._ipc_path
        self._ipc_path = None
        self._duration = 0
        self._position = 0
        if path and os.path.exists(path):
            try:
                os.unlink(path)
            except:
                pass

    # ── Player control ──

    def stop(self):
        self._cancel.set()
        with self._lock:
            proc = self._proc
            self._proc = None
        if proc:
            try:
                proc.send_signal(signal.SIGTERM)
                proc.kill()
            except:
                pass
        self._cleanup_ipc()
        self._track = None
        self._paused = False
        self._set_state("stopped")

    def play(self, track):
        self.stop()
        cancel = threading.Event()
        self._cancel = cancel
        self._track = track
        self._set_state("loading")
        threading.Thread(target=self._do_play, args=(track, cancel), daemon=True).start()

    def play_next_in_queue(self):
        with self._lock:
            if not self._queue:
                return False
            track = self._queue.pop(0)
        self._cancel.set()
        with self._lock:
            proc = self._proc
            self._proc = None
        if proc:
            try:
                proc.send_signal(signal.SIGTERM)
                proc.kill()
            except:
                pass
        self._cleanup_ipc()
        self._paused = False
        cancel = threading.Event()
        self._cancel = cancel
        self._track = track
        self._set_state("loading")
        threading.Thread(target=self._do_play, args=(track, cancel), daemon=True).start()
        return True

    def set_queue(self, tracks):
        self._queue = list(tracks)

    def _do_play(self, track, cancel):
        url = get_stream_url(track["id"], cancel)
        if cancel.is_set():
            return
        if not url:
            self._set_state("failed")
            return
        ipc = f"/tmp/ymusic-{random.randint(10000,99999)}.sock"
        self._ipc_path = ipc
        cmd = ["mpv", f"--input-ipc-server={ipc}", "--no-video", "--no-terminal",
               url]
        env = os.environ.copy()
        env["PATH"] = os.path.expanduser("~/.deno/bin") + ":" + env.get("PATH", "")
        proc = subprocess.Popen(cmd, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, env=env)
        with self._lock:
            self._proc = proc
        dur = track.get("duration", 0) or 0
        self._duration = dur
        self._start_polling(cancel)
        self._set_state("playing")
        proc.wait()
        with self._lock:
            self._proc = None
        self._cleanup_ipc()
        if cancel.is_set():
            return
        self._set_state("ended")

    def seek(self, pos):
        self._send_ipc({"command": ["set_property", "time-pos", float(pos)]})

    def toggle_pause(self):
        self._paused = not self._paused
        self._send_ipc({"command": ["set_property", "pause", self._paused]})
        return self._paused

    def set_volume(self, vol):
        self._volume = vol
        self._send_ipc({"command": ["set_property", "volume", vol]})

    def set_loop(self, active):
        self._loop = "yes" if active else "no"
        self._send_ipc({"command": ["set_property", "loop-file", self._loop]})

    def _set_state(self, state):
        self._state = state
        if self._on_state:
            GLib.idle_add(self._on_state, state)


