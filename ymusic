        bot.append(self.status_label)
        vbox.append(bot)

        win.set_child(vbox)

        kc = Gtk.EventControllerKey()
        kc.connect("key-pressed", self.on_key)
        win.add_controller(kc)

        win.connect("close-request", lambda w: (self.player.stop(), False)[1])

        win.present()
        self.win = win
        self.show_liked()

    def on_key(self, ctrl, keyval, keycode, state):
        if state & Gdk.ModifierType.CONTROL_MASK:
            if keyval == Gdk.KEY_f:
                self.search_entry.grab_focus()
                return True
            if keyval == Gdk.KEY_l:
                self.show_liked()
                return True
        return False

    def set_status(self, text):
        self.status_label.set_label(text)

    def clear_list(self, lb):
        if lb is self.results_list:
            self._play_rows_res.clear()
        else:
            self._play_rows_recs.clear()
        row = lb.get_first_child()
        while row:
            nxt = row.get_next_sibling()
            lb.remove(row)
            row = nxt

    # ── Player state callback (called from PlayerManager thread via GLib.idle_add) ──

    def _on_player_state(self, state):
        if state == "loading":
            self.stop_btn.set_sensitive(True)
            self.play_pause_btn.set_sensitive(False)
            self.play_pause_btn.set_label("▶")
            self.seek_scale.set_sensitive(False)
            self.prev_btn.set_sensitive(False)
            self.next_btn.set_sensitive(False)
            self.set_status("Loading stream...")
            self.np_dur.set_label("Loading...")
            self._refresh_all_play_buttons()
        elif state == "playing":
            track = self.player.track
            if not track:
                return
            self.stop_btn.set_sensitive(True)
            self.like_btn.set_sensitive(True)
            self.play_pause_btn.set_sensitive(True)
            self.play_pause_btn.set_label("⏸" if not self.player.paused else "▶")
            self.prev_btn.set_sensitive(True)
            self.next_btn.set_sensitive(True)
            dur = self.player.duration or track.get("duration", 0)
            self.seek_scale.set_range(0, dur)
            self.seek_scale.set_sensitive(True)
            self.set_status(f"Playing: {track['title'][:50]}")
            self.np_dur.set_label(fmt_dur(dur))
            self._refresh_all_play_buttons()
            tid = track["id"]
            cancel = self.player._cancel
            query = f"{track['uploader']} {track['title'][:30]}"
            threading.Thread(target=lambda: GLib.idle_add(
                self._show_recs, get_related(query, tid, 20, cancel=cancel)
            ), daemon=True).start()
        elif state == "failed":
            self.stop_btn.set_sensitive(False)
            self.like_btn.set_sensitive(False)
            self.play_pause_btn.set_sensitive(False)
            self.play_pause_btn.set_label("▶")
            self.seek_scale.set_sensitive(False)
            self.prev_btn.set_sensitive(False)
            self.next_btn.set_sensitive(False)
            self.set_status("Failed to get stream - try again")
            self.np_dur.set_label("Failed")
            self._refresh_all_play_buttons()
        elif state == "stopped":
            self.stop_btn.set_sensitive(False)
            self.play_pause_btn.set_sensitive(False)
            self.play_pause_btn.set_label("▶")
            self.seek_scale.set_sensitive(False)
            self.seek_scale.set_value(0)
            self.time_label.set_label("0:00")
            self.prev_btn.set_sensitive(False)
            self.next_btn.set_sensitive(False)
            self.set_status("Stopped")
            self._refresh_all_play_buttons()
        elif state == "ended":
            if self.player.play_next_in_queue():
                return
            self.stop_btn.set_sensitive(False)
            self.like_btn.set_sensitive(False)
            self.play_pause_btn.set_sensitive(False)
            self.play_pause_btn.set_label("▶")
            self.seek_scale.set_sensitive(False)
            self.seek_scale.set_value(0)
            self.time_label.set_label("0:00")
            self.prev_btn.set_sensitive(False)
            self.next_btn.set_sensitive(False)
            self.set_status("Playback ended")
            self.np_dur.set_label("Finished")
            self._refresh_all_play_buttons()

    def _on_position_update(self, position):
        if not self.player._seeking:
            self.seek_scale.set_value(position)
            self.time_label.set_label(fmt_dur(position))

    def _toggle_play_pause(self):
        paused = self.player.toggle_pause()
        self.play_pause_btn.set_label("▶" if paused else "⏸")

    def _on_seek(self, scale, scroll, value):
        self.player._seeking = True
        self.player.seek(value)
        self.time_label.set_label(fmt_dur(value))
        if self._seek_timeout:
            GLib.source_remove(self._seek_timeout)
        self._seek_timeout = GLib.timeout_add(500, self._clear_seeking)

    def _clear_seeking(self):
        self.player._seeking = False
        self._seek_timeout = 0
        return False

    def _on_volume(self, scale, scroll, value):
        self.player.set_volume(int(value))

    def _refresh_all_play_buttons(self):
        for d in (self._play_rows_res, self._play_rows_recs):
            for tid, widgets in list(d.items()):
                pb = widgets["play_btn"]
                sl = widgets["state_label"]
                pt = self.player.track
                sl.remove_css_class("playing-label")
                sl.remove_css_class("loading-label")
                if pt and pt["id"] == tid and self.player.state == "playing":
                    pb.set_visible(False)
                    sl.set_text("▶ Playing"); sl.set_visible(True)
                    sl.add_css_class("playing-label")
                elif pt and pt["id"] == tid and self.player.state == "loading":
                    pb.set_visible(False)
                    sl.set_text("⟳ Loading"); sl.set_visible(True)
                    sl.add_css_class("loading-label")
                else:
                    pb.set_visible(True)
                    sl.set_visible(False)

    # ── Search ──

    def do_search(self):
        q = self.search_entry.get_text().strip()
        if not q:
            return
        self.set_status(f"Searching: {q}...")
        threading.Thread(target=lambda: GLib.idle_add(self._show_results, search_yt(q), q), daemon=True).start()

    def _show_results(self, results, query=""):
        self.current_results = results
        self.clear_list(self.results_list)
        self.view_toolbar.set_visible(False)
        if not results:
            l = Gtk.Label(label="No results found"); l.set_margin_top(30)
            self.results_list.append(l)
            self.results_header.set_label("Results"); self.set_status("No results")
            return
        self.results_header.set_label(f"Results — {len(results)}")
        self.set_status(f"Found {len(results)} tracks")
        for i, t in enumerate(results):
            self._add_result_row(t)
            if i < 3:
                threading.Thread(target=lambda v=t["id"]: get_stream_url(v), daemon=True).start()
        self._refresh_all_play_buttons()

    def _add_result_row(self, track, liked_override=None):
        liked = liked_override if liked_override is not None else is_liked(track["id"])
        row = Gtk.ListBoxRow(); row.set_selectable(False)
        box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=6)
        box.set_margin_start(8); box.set_margin_end(8)
        box.set_margin_top(6); box.set_margin_bottom(6)

        info = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2); info.set_hexpand(True)

        tl = Gtk.Label(label=track["title"])
        tl.set_halign(Gtk.Align.START); tl.set_wrap(True); tl.set_max_width_chars(35)
        tl.add_css_class("result-title"); info.append(tl)

        dur = fmt_dur(track["duration"])
        views = fmt_views(track.get("views",0))
        sub = f"{track['uploader']}  •  {dur}" + (f"  •  {views}" if views else "")
        sl = Gtk.Label(label=sub)
        sl.set_halign(Gtk.Align.START); sl.add_css_class("result-sub"); info.append(sl)
        box.append(info)

        play_btn = Gtk.Button(label="▶ Play")
        play_btn.add_css_class("play-btn")
        play_btn.connect("clicked", lambda b, t=track: self.play_track(t))

        state_label = Gtk.Label(label="")
        state_label.set_visible(False)

        self._play_rows_res[track["id"]] = {"play_btn": play_btn, "state_label": state_label}

        box.append(play_btn)
        box.append(state_label)

        lb = Gtk.Button(label="♥" if liked else "♡")
        lb.add_css_class("liked-btn" if liked else "like-btn")
        lb.connect("clicked", lambda b, t=track, bx=box: self._toggle_result_like(t, bx))
        box.append(lb)

        row.set_child(box); self.results_list.append(row)

    def _toggle_result_like(self, track, box):
        liked = toggle_like(track)
        for c in box:
            if isinstance(c, Gtk.Button) and c.get_label() in ("♥","♡"):
                c.set_label("♥" if liked else "♡")
                c.remove_css_class("liked-btn"); c.remove_css_class("like-btn")
                c.add_css_class("liked-btn" if liked else "like-btn")

    def _toggle_like_current(self):
        if not self.player.track:
            return
        liked = toggle_like(self.player.track)
        self.like_btn.set_label("♥ Liked" if liked else "♡ Like")
        self.like_btn.remove_css_class("liked-btn"); self.like_btn.remove_css_class("like-btn")
        self.like_btn.add_css_class("liked-btn" if liked else "like-btn")

    def _toggle_rec_like(self, track, btn):
        liked = toggle_like(track)
        btn.set_label("♥" if liked else "♡")
        btn.remove_css_class("liked-btn"); btn.remove_css_class("like-btn")
        btn.add_css_class("liked-btn" if liked else "like-btn")

    # ── Playback ──

    def play_track(self, track):
        self.player.play(track)
        self.current_track = track
        liked = is_liked(track["id"])
        self.np_title.set_label(track["title"])
        self.np_artist.set_label(track["uploader"])
        self.np_dur.set_label("Loading stream...")
        self.like_btn.set_label("♥ Liked" if liked else "♡ Like")
        self.like_btn.remove_css_class("liked-btn"); self.like_btn.remove_css_class("like-btn")
        self.like_btn.add_css_class("liked-btn" if liked else "like-btn")
        self.like_btn.set_sensitive(False)

    def stop_playback(self):
        self.player.stop()

    def _prev_track(self):
        if self.player.state == "playing":
            self.player.seek(0)

    def _next_track(self):
        if self.player.queue:
            self.player.play_next_in_queue()



    # ── Recommendations ──

    def _show_recs(self, recs):
        self.current_recs = recs; self.clear_list(self.recs_list)
        if not recs:
            self.recs_header.set_label("Recommendations")
            l = Gtk.Label(label="No recommendations"); l.set_margin_top(20)
            self.recs_list.append(l)
            return
        self.recs_header.set_label(f"Recommendations — {len(recs)}")
        for i, t in enumerate(recs):
            row = Gtk.ListBoxRow(); row.set_selectable(False)
            box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=4)
            box.set_margin_start(6); box.set_margin_end(6)
            box.set_margin_top(4); box.set_margin_bottom(4)

            info = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=1); info.set_hexpand(True)
            tc = t["title"][:38]+"..." if len(t["title"])>38 else t["title"]
            tl = Gtk.Label(label=tc); tl.set_halign(Gtk.Align.START)
            tl.set_wrap(True); tl.set_max_width_chars(30); tl.add_css_class("rec-title"); info.append(tl)
            sl2 = Gtk.Label(label=f"{t['uploader']}  •  {fmt_dur(t['duration'])}")
            sl2.set_halign(Gtk.Align.START); sl2.add_css_class("rec-sub"); info.append(sl2)
            box.append(info)

            play_btn = Gtk.Button(label="▶")
            play_btn.add_css_class("play-btn")
            play_btn.connect("clicked", lambda b, t=t: self.play_track(t))

            state_label = Gtk.Label(label="")
            state_label.set_visible(False)

            self._play_rows_recs[t["id"]] = {"play_btn": play_btn, "state_label": state_label}
            box.append(play_btn)
            box.append(state_label)

            liked = is_liked(t["id"])
            lb = Gtk.Button(label="♥" if liked else "♡")
            lb.add_css_class("liked-btn" if liked else "like-btn")
            lb.set_margin_start(2)
            lb.connect("clicked", lambda b, t=t: self._toggle_rec_like(t, b))
            box.append(lb)

            row.set_child(box); self.recs_list.append(row)

            if i < 3:
                threading.Thread(target=lambda v=t["id"]: get_stream_url(v), daemon=True).start()

        self._refresh_all_play_buttons()

    # ── Liked view ──

    def show_liked(self):
        self.liked_tracks = load_liked(); self.clear_list(self.results_list)
        if not self.liked_tracks:
            self.view_toolbar.set_visible(False)
            self.results_header.set_label("♥ Liked Songs")
            l = Gtk.Label(label="No liked songs yet.\nClick ♡ on any track to save it.")
            l.set_margin_top(40); self.results_list.append(l)
            self.set_status("0 liked songs"); return
        self.view_toolbar.set_visible(True)
        self.results_header.set_label(f"♥ Liked Songs — {len(self.liked_tracks)}")
        self.set_status(f"{len(self.liked_tracks)} liked songs")
        for t in self.liked_tracks:
            self._add_result_row(t, liked_override=True)
        self._refresh_all_play_buttons()

    # ── Play All / Shuffle ──

    def _play_all_liked(self):
        tracks = load_liked()
        if not tracks:
            self.set_status("No liked songs to play")
            return
        self.player.set_queue(tracks[1:])
        self.play_track(tracks[0])

    def _shuffle_liked(self):
        tracks = load_liked()
        if not tracks:
            self.set_status("No liked songs to shuffle")
            return
        shuffled = list(tracks)
        random.shuffle(shuffled)
        self.player.set_queue(shuffled[1:])
        self.play_track(shuffled[0])


def main():
    db = os.path.expanduser("~/.deno/bin")
    if db not in os.environ.get("PATH",""):
        os.environ["PATH"] = db + ":" + os.environ.get("PATH","")
    app = YMusicApp()
    app.run(sys.argv)


if __name__ == "__main__":
    main()
